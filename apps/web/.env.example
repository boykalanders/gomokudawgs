# Active network: 11155111 = Sepolia (default), 1 = Ethereum mainnet.
# Contract addresses live in the dual-network registry in lib/env.ts; override
# per key with NEXT_PUBLIC_POOLDAWGS_ADDRESS / _DDAWGS_TOKEN_ADDRESS /
# _POOLDAWGS_NFT_ADDRESS / _CHESS_NFT_ADDRESS if you redeploy.
NEXT_PUBLIC_CHAIN_ID=11155111

# Authoritative game server (live multiplayer). For a DEPLOYED site this must
# be a public, HTTPS/WSS URL of a hosted game server — NOT localhost (a browser
# on https:// cannot open ws://localhost, and localhost isn't your server).
# Practice + wallet/NFT/lobby-create work without it.
NEXT_PUBLIC_SERVER_URL=http://localhost:4000

# WalletConnect / Reown project id — a real 32-hex-char id from
# https://cloud.reown.com (free). Leave blank to use injected (MetaMask) +
# Coinbase wallets only; a wrong/short value breaks WalletConnect.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
