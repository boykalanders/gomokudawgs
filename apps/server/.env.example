PORT=4000

# Comma-separated origins allowed to connect (the Next.js app)
CORS_ORIGINS=http://localhost:3000

# ── Chain wiring ────────────────────────────────────────────────
# Leave RPC_URL / CONTRACT_ADDRESS empty to run in chain-less dev
# mode (ad-hoc rooms, no settlement) for local play-testing.
RPC_URL=
CONTRACT_ADDRESS=

# Contract OWNER key — the relayer that calls finishGame.
# Production: inject from KMS/secret manager. NEVER commit a real key.
OWNER_PRIVATE_KEY=

# Override the 4-minute shot clock (ms) — tests/dev only.
SHOT_CLOCK_MS=
