# deps — matches at every level: root AND each workspace package
# (apps/server, apps/web, packages/contracts|engine|shared)
**/node_modules/
.pnpm-store/

# builds (per-package outputs)
**/dist/
**/.next/
**/.turbo/
out/
*.tsbuildinfo
next-env.d.ts
coverage/

# hardhat
packages/contracts/artifacts/
packages/contracts/cache/
packages/contracts/typechain-types/
# dev-chain proxy manifests only — manifests for real networks (mainnet,
# sepolia, …) must be committed: hardhat-upgrades needs them to upgrade.
.openzeppelin/unknown-*.json

# env / secrets — relayer owner key must NEVER be committed
.env
.env.*
!.env.example
*.pem

# local-chain run artifacts (regenerated by deploy:local)
local-deployment.json

# deploy targets
.vercel/

# reference fork (vendored separately, not part of the build)
reference/*.zip

# scratch / verification output
asset-preview.*
*.log
.DS_Store
